<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Job Role</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/viewJobRoles.css">
    <link rel="icon" href="/images/kainos_favicon.ico" type="image/x-icon">
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="header-left">
                <h1><%= jobRole.name %></h1>
                <p>Job Role Details</p>
            </div>
            <a href="/job-roles" class="add-btn">Back to Job Roles</a>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Field</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Name</strong></td>
                    <td><%= jobRole.name %></td>
                </tr>
                <tr>
                    <td><strong>Level</strong></td>
                    <td><%= jobRole.level %></td>
                </tr>
                <tr>
                    <td><strong>Capability</strong></td>
                    <td><%= jobRole.capability %></td>
                </tr>
                <tr>
                    <td><strong>Description</strong></td>
                    <td><%= jobRole.description %></td>
                </tr>
            </tbody>
        </table>
    </div>
</body>
</html>
