<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Add New Employee</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/addEmployee.css">
</head>

<body>

    <%- include('partials/navBar') %>

    <!-- Top navigation: View All Employees button -->
    <div class="top-nav">
        <a href="/employees" class="view-btn">👥 View All Employees</a>
    </div>

    <!-- ===== MAIN FORM CARD ===== -->
    <div class="form-container">
        <div class="form-header">
            <div class="icon">👤</div>
            <h1>Add New Employee</h1>
            <p class="subtitle">Fill in the details below to create a new record</p>
        </div>

        <form id="employeeForm" novalidate>

            <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" placeholder="John Smith">
                <div class="error-msg" id="nameError">Name is required</div>
            </div>

            <div class="form-group">
                <label for="address">Address</label>
                <input type="text" id="address" name="address" placeholder="123 Belfast Road">
                <div class="error-msg" id="addressError">Address is required</div>
            </div>

            <div class="form-group">
                <label for="salary">Salary (£)</label>
                <input type="number" id="salary" name="salary" placeholder="35000">
                <div class="error-msg" id="salaryError">Salary must be a positive number</div>
            </div>

            <div class="form-group">
                <label for="role">Role</label>
                <input type="text" id="role" name="role" placeholder="Software Engineer">
                <div class="error-msg" id="roleError">Role is required</div>
            </div>

            <button type="submit">Add Employee</button>
        </form>
    </div>

    <!-- ===== SUCCESS POPUP ===== -->
    <div class="popup-overlay" id="popup">
        <div class="popup-box">
            <div class="success-icon">✓</div>
            <h2>Success!</h2>
            <p id="popupMessage">Employee saved successfully</p>
            <div class="popup-buttons">
                <button onclick="closePopup()">Add Another</button>
                <a href="/employees" class="view-all-link">View All</a>
            </div>
        </div>
    </div>

    <script src="/javascripts/addEmployee.js"></script>

    <%- include('partials/footer') %>

</body>

</html>