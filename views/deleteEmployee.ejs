<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Delete Employee</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/deleteEmployee.css">
</head>

<body>

    <div class="delete-card">

        <!-- Warning icon -->
        <div class="warning-icon">⚠️</div>

        <h1>Delete Employee?</h1>
        <p class="subtitle">Are you sure you want to delete this employee record?</p>

        <!-- Employee info preview -->
        <div class="employee-info">
            <div class="info-row">
                <span class="info-label">Emp No.</span>
                <span class="info-value"><%= employee.employeeNumber %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Name</span>
                <span class="info-value"><%= employee.name %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Role</span>
                <span class="info-value"><%= employee.role %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Salary</span>
                <span class="info-value">£<%= Number(employee.salary).toLocaleString() %></span>
            </div>
        </div>

        <!-- Warning message -->
        <div class="warning-msg">
            ⚠ This action cannot be undone. The employee record will be permanently removed.
        </div>

        <!-- Action buttons in a form so we can POST the delete -->
        <form action="/employees/delete/<%= employee.id %>" method="post">
            <div class="actions">
                <a href="/employees" class="btn btn-cancel">No, Cancel</a>
                <button type="submit" class="btn btn-delete">Yes, Delete</button>
            </div>
        </form>

    </div>

</body>

</html>