<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Employee Detail - <%= employee.name %></title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/employeeDetail.css">
</head>

<body>

    <!-- Back to all employees button -->
    <div class="top-nav">
        <a href="/employees" class="back-btn">← Back to All Employees</a>
    </div>

    <!-- Main employee detail card -->
    <div class="detail-card">

        <!-- Profile header with avatar and name -->
        <div class="profile-header">
            <div class="avatar">
                <%= employee.name.charAt(0).toUpperCase() %>
            </div>
            <h1><%= employee.name %></h1>
            <span class="emp-badge"><%= employee.employeeNumber %></span>
        </div>

        <!-- Employee detail rows -->
        <div class="detail-row">
            <span class="detail-label">Employee Number</span>
            <span class="detail-value"><%= employee.employeeNumber %></span>
        </div>

        <div class="detail-row">
            <span class="detail-label">Name</span>
            <span class="detail-value"><%= employee.name %></span>
        </div>

        <div class="detail-row">
            <span class="detail-label">Address</span>
            <span class="detail-value"><%= employee.address %></span>
        </div>

        <div class="detail-row">
            <span class="detail-label">Role</span>
            <span class="detail-value"><%= employee.role %></span>
        </div>

        <div class="detail-row">
            <span class="detail-label">Salary</span>
            <span class="detail-value salary">£<%= Number(employee.salary).toLocaleString() %></span>
        </div>

        <!-- Edit / Delete buttons (placeholders for future user stories) -->
        <div class="actions">
            <button class="btn btn-edit" data-id="<%= employee.id %>" id="editBtn">Edit</button>
<button class="btn btn-delete" data-id="<%= employee.id %>" id="deleteBtn">Delete</button>
        </div>

    </div>

    <script src="/javascripts/employeeDetail.js"></script>

</body>

</html>