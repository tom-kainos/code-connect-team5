<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Roles</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/viewJobRoles.css"
    
</head>
<body>
    <%- include('partials/navBar') %>
    <div class="container">
        <div class="header">
            <div class="header-left">
                <h1>Job Roles</h1>
                <p>View and manage Kainos job roles</p>
            </div>
            <a href="/job-roles/add" class="add-btn">+ Add Job Role</a>
        </div>

        <% if (jobRoles && jobRoles.length > 0) { %>
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Level</th>
                            <th>Capability</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% jobRoles.forEach(jobRole => { %>
                            <tr>
                                <td><%= jobRole.name %></td>
                                <td><%= jobRole.level %></td>
                                <td><%= jobRole.capability %></td>
                                <td><%= jobRole.description %></td>
                                <td>
                                    <div class="actions">
                                        <a href="/job-roles/<%= jobRole.id %>" class="btn-view">View</a>
                                        <a href="/job-roles/edit/<%= jobRole.id %>" class="btn-edit">Edit</a>
                                        <form action="/job-roles/delete/<%= jobRole.id %>" method="post" style="display:inline;">
                                            <button type="submit" class="btn-delete">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="icon">📋</div>
                <h3>No job roles yet</h3>
                <p>Click "Add Job Role" to create your first role</p>
            </div>
        <% } %>
    </div>

    <%- include('partials/footer') %>
</body>
</html>
