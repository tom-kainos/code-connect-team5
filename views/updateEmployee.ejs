<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Employee</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/addEmployee.css">
    <link rel="icon" href="/images/kainos_favicon.ico" type="image/x-icon">
</head>

<body>

    <%- include('partials/navBar') %>
<main>
    <!-- Top navigation: View All Employees button -->
    <div class="top-nav">
        <a href="/employees" class="view-btn">👥 View All Employees</a>
    </div>

    <!-- ===== MAIN FORM CARD ===== -->
    <div class="form-container">
        <div class="form-header">
            <div class="icon">👤</div>
            <h1>Update Employee</h1>
            <p class="subtitle">Edit the details below and save changes</p>
        </div>

        <form id="employeeForm" action="/employees/update/<%= employee.id %>" method="POST" novalidate>

            <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" placeholder="John Smith" value="<%= employee.name %>">
                <div class="error-msg" id="nameError">Name is required</div>
            </div>

            <div class="form-group">
                <label for="address">Address</label>
                <input type="text" id="address" name="address" placeholder="123 Belfast Road" value="<%= employee.address %>">
                <div class="error-msg" id="addressError">Address is required</div>
            </div>

            <div class="form-group">
                <label for="salary">Salary (£)</label>
                <input type="number" id="salary" name="salary" placeholder="35000" value="<%= employee.salary %>">
                <div class="error-msg" id="salaryError">Salary must be a positive number</div>
            </div>

            <div class="form-group">
                <label for="role">Role</label>
                <select id="role" name="role">
                    <option value="">Select a role</option>
                    <% jobRoles.forEach(jobRole => { %>
                        <option value="<%= jobRole.name %>" <%= employee.role === jobRole.name ? 'selected' : '' %>><%= jobRole.name %></option>
                    <% }); %>
                </select>
                <div class="error-msg" id="roleError">Role is required</div>
            </div>

            <button type="submit">Update Employee</button>
        </form>
    </div>
    <script src="/javascripts/updateEmployee.js"></script>
</main>
    <%- include('partials/footer') %>

</body>

</html>